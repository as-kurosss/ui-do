{
  "$preset": "list-detail",
  "$description": "List panel on the left (flex-col) + detail panel on the right",
  "root": {
    "kind": "layout",
    "id": "PRESET_ROOT",
    "display": "flex",
    "direction": "row",
    "gap": 0,
    "className": "min-h-screen",
    "children": [
      {
        "kind": "layout",
        "id": "PRESET_1",
        "display": "flex",
        "direction": "column",
        "gap": 2,
        "className": "w-80 border-r p-4",
        "children": [
          { "kind": "component", "id": "PRESET_2", "component": "Input", "props": { "placeholder": "Search..." } },
          { "kind": "component", "id": "PRESET_3", "component": "Separator" },
          { "kind": "component", "id": "PRESET_4", "component": "Button", "variants": { "variant": "ghost", "size": "default" }, "className": "w-full justify-start", "children": [
            { "kind": "text", "id": "PRESET_5", "text": "Item 1" }
          ]},
          { "kind": "component", "id": "PRESET_6", "component": "Button", "variants": { "variant": "ghost", "size": "default" }, "className": "w-full justify-start", "children": [
            { "kind": "text", "id": "PRESET_7", "text": "Item 2" }
          ]},
          { "kind": "component", "id": "PRESET_8", "component": "Button", "variants": { "variant": "ghost", "size": "default" }, "className": "w-full justify-start", "children": [
            { "kind": "text", "id": "PRESET_9", "text": "Item 3" }
          ]}
        ]
      },
      {
        "kind": "layout",
        "id": "PRESET_10",
        "display": "flex",
        "direction": "column",
        "gap": 4,
        "className": "flex-1 p-6",
        "children": [
          { "kind": "text", "id": "PRESET_11", "text": "Detail Title", "as": "h1", "className": "text-2xl font-bold" },
          { "kind": "text", "id": "PRESET_12", "text": "Detail description and content goes here. This panel displays the selected item's details.", "as": "p", "className": "text-muted-foreground" },
          { "kind": "component", "id": "PRESET_13", "component": "Separator" },
          { "kind": "component", "id": "PRESET_14", "component": "Card", "children": [
            { "kind": "component", "id": "PRESET_15", "component": "CardHeader", "children": [
              { "kind": "component", "id": "PRESET_16", "component": "CardTitle", "children": [
                { "kind": "text", "id": "PRESET_17", "text": "Details" }
              ]}
            ]},
            { "kind": "component", "id": "PRESET_18", "component": "CardContent", "children": [] }
          ]}
        ]
      }
    ]
  }
}
