{
  "$preset": "auth",
  "$description": "Centered card with CardHeader + CardContent, for login/signup forms",
  "root": {
    "kind": "layout",
    "id": "PRESET_ROOT",
    "display": "flex",
    "direction": "column",
    "gap": 4,
    "align": "center",
    "justify": "center",
    "className": "min-h-screen",
    "children": [
      {
        "kind": "component",
        "id": "PRESET_1",
        "component": "Card",
        "className": "w-80",
        "children": [
          {
            "kind": "component",
            "id": "PRESET_2",
            "component": "CardHeader",
            "children": [
              {
                "kind": "component",
                "id": "PRESET_3",
                "component": "CardTitle",
                "variants": { "size": "default" },
                "children": [
                  { "kind": "text", "id": "PRESET_4", "text": "Title", "as": "h2" }
                ]
              }
            ]
          },
          {
            "kind": "component",
            "id": "PRESET_5",
            "component": "CardContent",
            "children": []
          }
        ]
      }
    ]
  }
}
